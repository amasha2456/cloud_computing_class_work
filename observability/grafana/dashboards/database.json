{
  "title": "Database (Postgres)",
  "uid": "database",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Connections by Database",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname!~\"template.*\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Transaction Commit Rate",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname!~\"template.*\"}[5m])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    }
  ]
}
